    function openEditModalById(id) {
       const item = globalData.find(x => String(x.id) === String(id));
       if (item) {
           document.getElementById('modalTitle').textContent = "แก้ไขข้อมูลคุณแม่บ้านกลุ่ม H";
           document.getElementById('recordId').value = item.id;
           document.getElementById('maidCode').value = item.maidCode;
           document.getElementById('name').value = item.name;
           document.getElementById('idCard').value = item.idCard || ""; formatIdCard(document.getElementById('idCard'));
           document.getElementById('phone').value = item.phone;
           document.getElementById('contactChannel').value = item.contactChannel;
           
           if(item.holdDate) document.getElementById('holdDate')._flatpickr.setDate(item.holdDate); else document.getElementById('holdDate')._flatpickr.clear();
           
           document.getElementById('needsRetrain').value = item.needsRetrain || "ไม่ต้อง";
           document.getElementById('trainingCenter').value = item.trainingCenter || "";
           toggleRetrain();

           document.getElementById('masterType').value = item.masterType || "";

           if(item.lastVerifyDate) document.getElementById('lastVerifyDate')._flatpickr.setDate(item.lastVerifyDate); else document.getElementById('lastVerifyDate')._flatpickr.clear();
           document.getElementById('verifyMethod').value = item.verifyMethod || "ใช้ผลตรวจเดิม";
           document.getElementById('hasFastTrackStatus').value = item.fastTrackStatus || "";
           
           calculateVerifyValidity();
           toggleVerifyAction();

           const tags = item.tags || [];
           document.querySelectorAll('.dynamic-tag').forEach(cb => { cb.checked = tags.includes(cb.value); });

           document.getElementById('status').value = item.status || "รอดำเนินการ";
           if(item.reactivationDate) document.getElementById('reactivationDate')._flatpickr.setDate(item.reactivationDate); else document.getElementById('reactivationDate')._flatpickr.clear();
           toggleKpiSection();
           renderKpiInputs(item.kpiJobs || []);

           currentHistory = item.history || []; renderTimeline();
           document.getElementById('newFollowNote').value = "";
           formModal.show();
       }
    }

    function toggleRetrain() {
        const val = document.getElementById('needsRetrain').value;
        const div = document.getElementById('retrainCenterDiv');
        if (val === 'ต้อง Retrain') div.style.display = 'block'; else div.style.display = 'none';
    }

    function calculateVerifyValidity() {
        const dateStr = document.getElementById('lastVerifyDate').value;
        const alertDiv = document.getElementById('verifyValidityAlert');
        const methodSel = document.getElementById('verifyMethod');
        
        if (!dateStr) {
            alertDiv.innerHTML = `<div class="alert alert-secondary py-2 mb-0 small">กรุณาระบุวันที่เพื่อคำนวณอายุผลตรวจ</div>`;
            return;
        }

        // 🌟 รองรับการแปลงวันที่ทั้งแบบ YYYY-MM-DD และแบบ D/M/YYYY (เช่น 9/1/2567) 🌟
        let passedDate;
        if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const [y, m, d] = dateStr.split('-');
            passedDate = new Date(y, parseInt(m) - 1, d);
        } else if (dateStr.includes('/')) {
            let parts = dateStr.split('/');
            if(parts.length === 3) {
                let d = parseInt(parts[0]);
                let m = parseInt(parts[1]) - 1;
                let y = parseInt(parts[2]);
                if (y > 2400) y -= 543;
                passedDate = new Date(y, m, d);
            } else {
                passedDate = new Date(dateStr);
            }
        } else {
            let parts = dateStr.split(' ');
            if (parts.length === 3) {
                let y = parseInt(parts[2]);
                let m = ["ม.ค.","ก.พ.","มี.ค.","เม.ย.","พ.ค.","มิ.ย.","ก.ค.","ส.ค.","ก.ย.","ต.ค.","พ.ย.","ธ.ค."].indexOf(parts[1]);
                let d = parseInt(parts[0]);
                if (y > 2400) y -= 543;
                passedDate = new Date(y, m, d);
            } else {
                passedDate = new Date(dateStr);
            }
        }
        
        if (isNaN(passedDate.getTime())) {
            alertDiv.innerHTML = `<div class="alert alert-danger py-2 mb-0 small fw-bold">รูปแบบวันที่ไม่ถูกต้อง</div>`;
            return;
        }

        const expiryDate = new Date(passedDate);
        expiryDate.setFullYear(expiryDate.getFullYear() + 1); 
        
        const today = new Date();
        today.setHours(0,0,0,0);
        
        const timeDiff = expiryDate.getTime() - today.getTime();
        const daysLeft = Math.ceil(timeDiff / (1000 * 3600 * 24));
        
        if (daysLeft < 0) {
            alertDiv.innerHTML = `<div class="alert alert-danger py-2 mb-0 small fw-bold"><i class="fas fa-times-circle me-1"></i> หมดอายุแล้ว (เกิน 1 ปี) - ต้องตรวจใหม่</div>`;
            methodSel.value = "ต้องส่งตรวจใหม่ผ่านระบบ";
        } else if (daysLeft < 90) {
            alertDiv.innerHTML = `<div class="alert alert-danger py-2 mb-0 small fw-bold"><i class="fas fa-exclamation-triangle me-1"></i> อายุเหลือน้อยกว่า 90 วัน (${daysLeft} วัน) - ต้องตรวจใหม่</div>`;
            methodSel.value = "ต้องส่งตรวจใหม่ผ่านระบบ";
        } else {
            alertDiv.innerHTML = `<div class="alert alert-success py-2 mb-0 small fw-bold"><i class="fas fa-check-circle me-1"></i> ใช้งานได้ (เหลือ ${daysLeft} วัน)</div>`;
            methodSel.value = "ใช้ผลตรวจเดิม";
        }
        toggleVerifyAction();
    }

    function toggleVerifyAction() {
        const val = document.getElementById('verifyMethod').value;
        const btnDiv = document.getElementById('fastTrackActionDiv');
        const statusSpan = document.getElementById('currentFtStatus');
        const currentStatus = document.getElementById('hasFastTrackStatus').value;
        
        if (val === 'ต้องส่งตรวจใหม่ผ่านระบบ' && document.getElementById('recordId').value) {
            btnDiv.style.display = 'block';
            statusSpan.textContent = `สถานะ FT ปัจจุบัน: ${currentStatus || 'ยังไม่ส่ง'}`;
            if (currentStatus) statusSpan.className = 'small fw-bold text-primary';
        } else {
            btnDiv.style.display = 'none';
        }
    }

    function toggleKpiSection() {
        const stat = document.getElementById('status').value;
        const kpiSec = document.getElementById('kpiSection');
        const reactDiv = document.getElementById('reactivationDateDiv');
        
        if (stat === 'เปิดระบบ') {
            kpiSec.classList.remove('d-none');
            reactDiv.style.display = 'block';
            const rDate = document.getElementById('reactivationDate');
            if(!rDate.value) rDate._flatpickr.setDate(new Date());
            calculateKpiDeadline();
        } else {
            kpiSec.classList.add('d-none');
            reactDiv.style.display = 'none';
        }
    }

    function calculateKpiDeadline() {
        const dateStr = document.getElementById('reactivationDate').value;
        const textDiv = document.getElementById('kpiDeadlineText');
        if (!dateStr) { textDiv.textContent = "กำหนดวันเปิดระบบเพื่อดูวันครบกำหนด"; return; }
        
        let parts = dateStr.split(' ');
        let y = parseInt(parts[2]); let m = ["ม.ค.","ก.พ.","มี.ค.","เม.ย.","พ.ค.","มิ.ย.","ก.ค.","ส.ค.","ก.ย.","ต.ค.","พ.ย.","ธ.ค."].indexOf(parts[1]); let d = parseInt(parts[0]);
        if (y > 2400) y -= 543;
        
        let openDate = new Date(y, m, d);
        let deadline = new Date(y, m, d);
        deadline.setDate(deadline.getDate() + 30); // 30 วัน
        
        const today = new Date(); today.setHours(0,0,0,0);
        const daysLeft = Math.ceil((deadline.getTime() - today.getTime()) / (1000 * 3600 * 24));
        
        let color = daysLeft < 0 ? "text-danger fw-bold" : (daysLeft <= 5 ? "text-warning fw-bold text-dark" : "text-primary fw-bold");
        let thDate = deadline.toLocaleDateString('th-TH', {day:'numeric', month:'short', year:'numeric'});
        
        textDiv.innerHTML = `ครบกำหนด: <b>${thDate}</b> <span class="${color}">(เหลือเวลา ${daysLeft} วัน)</span>`;
    }

    function renderKpiInputs(savedData) {
        const container = document.getElementById('kpiInputs');
        container.innerHTML = "";
        for (let i = 0; i < 4; i++) {
            let booking = "", job = "";
            if (savedData && savedData[i]) { booking = savedData[i].booking || ""; job = savedData[i].job || ""; }
            
            container.innerHTML += `
                <div class="kpi-row">
                    <div class="kpi-num">${i+1}</div>
                    <input type="text" class="form-control form-control-sm kpi-booking" placeholder="Booking Code" value="${booking}">
                    <input type="text" class="form-control form-control-sm kpi-jobid" placeholder="Job ID (ถ้ามี)" value="${job}">
                </div>
            `;
        }
    }

    function formatIdCard(input) {
      let v = input.value.replace(/\D/g, ''); if(v.length>13) v=v.substring(0,13);
      let f = ''; if(v.length>0) f+=v.substring(0,1); if(v.length>1) f+='-'+v.substring(1,5); if(v.length>5) f+='-'+v.substring(5,10); if(v.length>10) f+='-'+v.substring(10,12); if(v.length>12) f+='-'+v.substring(12,13);
      input.value = f;
      if(v.length===13) validateIdCard(input); else input.classList.remove('is-invalid', 'is-valid');
    }
    function validateIdCard(input) {
       const id = input.value.replace(/-/g, ''); if(id.length!==13) { input.classList.add('is-invalid'); return false; }
       let sum=0; for(let i=0; i<12; i++) sum+=parseFloat(id.charAt(i))*(13-i);
       if((11-(sum%11))%10 === parseFloat(id.charAt(12))) { input.classList.remove('is-invalid'); input.classList.add('is-valid'); return true; }
       else { input.classList.add('is-invalid'); return false; }
    }

    function addManualLog() {
        const note = document.getElementById('newFollowNote').value.trim();
        if(!note) return;
        const now = new Date();
        const dateStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
        currentHistory.unshift({ date: dateStr, note: note, user: currentUser });
        renderTimeline();
        document.getElementById('newFollowNote').value = "";
    }
    function renderTimeline() {
        const c = document.getElementById('timelineContainer'); c.innerHTML = "";
        if (!currentHistory.length) { c.innerHTML = '<div class="text-center text-muted small py-3">ยังไม่มีประวัติ</div>'; return; }
        let html = '<div class="timeline">';
        currentHistory.forEach((h, i) => {
             const u = h.user ? ` <small class="text-muted">(${h.user})</small>` : '';
             html += `<div class="timeline-item"><div class="timeline-date">${formatDateDisplay(h.date)}${u}</div>
                      <div class="timeline-content d-flex justify-content-between"><div>${h.note}</div><button class="btn btn-sm text-danger p-0 ms-2" onclick="removeLog(${i})">&times;</button></div></div>`;
        });
        html += '</div>'; c.innerHTML = html;
    }
    function removeLog(index) { currentHistory.splice(index, 1); renderTimeline(); }

    function sendToFastTrackFromModal() {
        const id = document.getElementById('recordId').value;
        if (!id) { Swal.fire('โปรดบันทึกข้อมูลก่อน', 'ต้องบันทึกรายชื่อลงระบบก่อนจึงจะส่ง Fast Track ได้', 'warning'); return; }
        
        Swal.fire({ title: 'ยืนยันส่งตรวจ?', icon: 'question', showCancelButton: true }).then(r => {
            if(r.isConfirmed) {
                showLoading();
                google.script.run.withSuccessHandler(res => {
                    hideLoading();
                    if(res.success) { Swal.fire('สำเร็จ', 'ส่งข้อมูลไปยังส่วนตรวจสอบประวัติแล้ว', 'success'); loadData(); formModal.hide(); }
                    else showError(res.message);
                }).sendHoldToFastTrack(id);
            }
        });
    }

    function saveData() {
       const idInput = document.getElementById('idCard');
       if(idInput.value && !validateIdCard(idInput)) { Swal.fire('เลขบัตรไม่ถูกต้อง', '', 'warning'); return; }
       
       let tags = [];
       document.querySelectorAll('.dynamic-tag:checked').forEach(cb => { tags.push(cb.value); });
       
       let kpiData = [];
       if (document.getElementById('status').value === 'เปิดระบบ') {
           const bInputs = document.querySelectorAll('.kpi-booking');
           const jInputs = document.querySelectorAll('.kpi-jobid');
           for(let i=0; i<4; i++) {
               kpiData.push({ booking: bInputs[i].value.trim(), job: jInputs[i].value.trim() });
           }
       }

       const form = {
          id: document.getElementById('recordId').value,
          maidCode: document.getElementById('maidCode').value,
          name: document.getElementById('name').value,
          idCard: document.getElementById('idCard').value.replace(/-/g, ''),
          phone: document.getElementById('phone').value,
          contactChannel: document.getElementById('contactChannel').value,
          holdDate: document.getElementById('holdDate').value,
          needsRetrain: document.getElementById('needsRetrain').value,
          trainingCenter: document.getElementById('trainingCenter').value,
          lastVerifyDate: document.getElementById('lastVerifyDate').value,
          verifyMethod: document.getElementById('verifyMethod').value,
          masterType: document.getElementById('masterType').value,
          tags: tags,
          status: document.getElementById('status').value,
          reactivationDate: document.getElementById('reactivationDate').value,
          kpiJobs: kpiData,
          history: currentHistory,
          officer: currentUser
       };

       if(!form.name || !form.maidCode) { Swal.fire('ข้อมูลไม่ครบ', 'ระบุรหัส และ ชื่อ-นามสกุล', 'warning'); return; }

       showLoading();
       google.script.run.withSuccessHandler(res => {
          hideLoading();
          if(res.success) { formModal.hide(); Swal.fire({ icon:'success', title:'บันทึกเรียบร้อย', timer: 1000, showConfirmButton:false }); loadData(); } 
          else showError(res.message);
       }).withFailureHandler(err => {
          hideLoading(); showError(err.message);
       }).saveHoldData(form);
    }

    function deleteItem(id) {
        Swal.fire({ title: 'ยืนยันลบ?', text: "เฉพาะ Admin เท่านั้นที่ลบได้", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33' }).then((r) => {
            if (r.isConfirmed) {
                showLoading();
                google.script.run.withSuccessHandler((res) => { 
                    hideLoading(); 
                    if(res.success) { Swal.fire('ลบแล้ว!', '', 'success'); loadData(); } else { showError(res.message); }
                }).deleteHoldData(id);
            }
        });
    }
