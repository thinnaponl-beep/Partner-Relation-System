  <script>
    let globalData = [], currentUser = "", isUserAdmin = false; 
    let centerOptions = [], masterTypeOptions = [], providerMap = {};
    let formModal;
    let currentHistory = [];

    window.onload = function() {
       formModal = new bootstrap.Modal(document.getElementById('formModal'));
       flatpickr(".datepicker", { dateFormat: "Y-m-d", altInput: true, altFormat: "j M Y", locale: "th" });
       
       // 🌟 1. ดึงรายชื่อพร้อม "วันที่ผลตรวจเดิมผ่าน" 🌟
       google.script.run.withSuccessHandler(res => { 
           if(res) {
               providerMap = res; 
           } 
       }).getGlobalProviderMapWithVerifyDate();

       loadData();
    };

    function loadData() {
       showLoading();
       google.script.run.withSuccessHandler(res => {
          hideLoading();
          globalData = res.data || []; 
          currentUser = res.currentUser; 
          isUserAdmin = res.isAdmin;
          centerOptions = res.onboardCenters || []; 
          masterTypeOptions = res.masterTypes || [];
          
          const ctrSel = document.getElementById('trainingCenter');
          ctrSel.innerHTML = '<option value="">เลือกศูนย์...</option>';
          if(centerOptions.length === 0) {
              ctrSel.innerHTML += '<option value="" disabled>-- โปรดเพิ่มศูนย์เทรนในหน้า Config --</option>';
          }
          centerOptions.forEach(x => ctrSel.add(new Option(x, x)));

          const mtSel = document.getElementById('masterType');
          mtSel.innerHTML = '<option value="">เลือกประเภท...</option>';
          if(masterTypeOptions.length === 0) {
              mtSel.innerHTML += '<option value="" disabled>-- โปรดเพิ่มประเภทในหน้า Config --</option>';
          }
          masterTypeOptions.forEach(x => mtSel.add(new Option(x, x)));

          let tagsHtml = '';
          let configTags = res.onboardTags || ['รูปโปรไฟล์', 'รูปอุปกรณ์']; 
          configTags.forEach((tag, idx) => {
              let tagId = 'dynamic_tag_' + idx;
              tagsHtml += `
                  <div>
                      <input type="checkbox" id="${tagId}" class="tag-checkbox dynamic-tag" value="${tag}">
                      <label for="${tagId}" class="tag-label"><i class="fas fa-tag me-1 text-muted"></i> ${tag}</label>
                  </div>
              `;
          });
          document.getElementById('dynamicTagsContainer').innerHTML = tagsHtml;

          filterTable();
       }).withFailureHandler(e => { hideLoading(); showError(e.message); }).getHoldData();
    }

    function formatDateDisplay(d) {
        if (!d) return '-';
        if (typeof d === 'string' && d.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const [y, m, day] = d.split('-');
            return `${day}/${m}/${parseInt(y) > 2400 ? parseInt(y)-543 : parseInt(y)+543}`;
        }
        const date = new Date(d);
        if (isNaN(date.getTime())) return d;
        return date.toLocaleDateString('th-TH', {day:'2-digit', month:'short', year:'2-digit'});
    }

    function renderTable(data) {
       const tbody = document.getElementById('tableBody'); tbody.innerHTML = "";
       if(!data || data.length === 0) { document.getElementById('noData').classList.remove('d-none'); return; }
       document.getElementById('noData').classList.add('d-none');

       data.forEach(row => {
          let tr = document.createElement('tr');
          
          let ftBadge = '<span class="text-muted">-</span>';
          if (row.fastTrackStatus) {
              let colorClass = 'bg-secondary';
              if (row.fastTrackStatus === 'Verified') colorClass = 'bg-success';
              else if (row.fastTrackStatus === 'Not Verified') colorClass = 'bg-danger';
              else if (row.fastTrackStatus === 'Pending Result' || row.fastTrackStatus === 'Sent') colorClass = 'bg-warning text-dark';
              ftBadge = `<span class="badge ${colorClass}">${row.fastTrackStatus}</span>`;
          } else if (row.verifyMethod === 'มีใบตรวจประวัติมาเอง') {
              ftBadge = `<span class="badge bg-light text-muted border">ตรวจเอง</span>`;
          }

          let statBadge = 'bg-secondary';
          if(row.status === 'เปิดระบบ') statBadge = 'bg-success';
          else if (row.status === 'รอดำเนินการ') statBadge = 'bg-warning text-dark';
          else if (row.status === 'ยกเลิก') statBadge = 'bg-danger';

          // 🌟 สร้าง HTML แสดง Tags ให้อยู่ใต้สถานะ
          let tagsHtml = "";
          if (row.tags && Array.isArray(row.tags) && row.tags.length > 0) {
              tagsHtml = '<div class="mt-2 d-flex flex-wrap gap-1 justify-content-center">';
              row.tags.forEach(t => {
                  tagsHtml += `<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle" style="font-size:0.65rem;">${t}</span>`;
              });
              tagsHtml += '</div>';
          }

          // คำนวณ KPI 4 งาน
          let kpiCount = 0;
          if (row.kpiJobs && Array.isArray(row.kpiJobs)) {
              kpiCount = row.kpiJobs.filter(j => j.booking.trim() !== "").length;
          }
          let kpiDisplay = row.status === 'เปิดระบบ' ? `<span class="badge bg-primary-subtle text-primary border px-2 py-1">${kpiCount} / 4 งาน</span>` : `<span class="text-muted small">-</span>`;

          let maidLink = row.maidCode ? `<a href="https://admin-test.beneat.co/professional/${row.maidCode}/profile" target="_blank" class="fw-bold text-primary text-decoration-none">${row.maidCode}</a>` : '-';
          let deleteBtn = isUserAdmin ? `<button class="btn btn-icon btn-sm" onclick="deleteItem('${row.id}')"><i class="fas fa-trash text-danger"></i></button>` : '';

          tr.innerHTML = `
             <td><div class="small text-muted mb-1">ID: ${row.id}</div>${maidLink}</td>
             <td class="fw-bold">${row.name}</td>
             <td><span class="badge bg-light text-dark border">${row.contactChannel || '-'}</span></td>
             <td class="text-danger small">${formatDateDisplay(row.holdDate)}</td>
             <td class="text-center">${ftBadge}</td> 
             <td class="text-center align-middle">
                 <span class="badge ${statBadge}">${row.status || '-'}</span>
                 ${tagsHtml}
             </td>
             <td class="text-success small fw-bold">${formatDateDisplay(row.reactivationDate)}</td>
             <td class="text-center">${kpiDisplay}</td>
             <td class="text-center">
                <button class="btn btn-icon btn-soft-warning text-dark btn-sm shadow-sm" onclick="openEditModalById('${row.id}')"><i class="fas fa-edit"></i></button>
                ${deleteBtn}
             </td>
          `;
          tbody.appendChild(tr);
       });
    }

    function filterTable() {
       const txt = document.getElementById('searchInput').value.toLowerCase();
       const status = document.getElementById('statusFilter').value;
       const filtered = globalData.filter(x => {
          const matchText = (String(x.name)+String(x.maidCode)+String(x.phone)).toLowerCase().includes(txt);
          const matchStatus = status === "" || String(x.status) === status;
          return matchText && matchStatus;
       });
       renderTable(filtered);
    }

    function searchMaidAuto(val) {
        const listContainer = document.getElementById('autocomplete-list');
        listContainer.innerHTML = '';
        
        if (!val || val.length < 2) return; 

        const searchVal = val.toLowerCase().trim();

        const matches = Object.keys(providerMap).filter(key => {
            const data = providerMap[key];
            return key.includes(searchVal) || 
                   (data.code && data.code.toLowerCase().includes(searchVal)) ||
                   (data.name && data.name.toLowerCase().includes(searchVal)); 
        });

        if (matches.length === 0) {
            const div = document.createElement('div');
            div.innerHTML = `<span class="text-primary fw-bold"><i class="fas fa-plus-circle me-1"></i> สร้างเป็นรายการใหม่ด้วยรหัส "${val}"</span>`;
            div.onclick = function() {
                document.getElementById('maidCode').value = val;
                listContainer.innerHTML = '';
            };
            listContainer.appendChild(div);
            return;
        }

        matches.slice(0, 8).forEach(idCardClean => {
            const data = providerMap[idCardClean];
            const div = document.createElement('div');
            
            let vDateDisplay = data.verifyDate ? `<br><small class="text-success"><i class="fas fa-check-circle"></i> ผ่านล่าสุด: ${data.verifyDate}</small>` : '';
            
            div.innerHTML = `<strong>${data.code}</strong> - ${data.name} <br><small class="text-muted">บัตร: ${idCardClean}</small>${vDateDisplay}`;
            div.onclick = function() {
                document.getElementById('maidCode').value = data.code;
                document.getElementById('name').value = data.name;
                document.getElementById('idCard').value = idCardClean; 
                formatIdCard(document.getElementById('idCard')); 
                
                // 🌟 ระบบยัด "วันที่ผลตรวจเดิมผ่าน" ลงไปให้อัตโนมัติ 🌟
                let fp = document.getElementById('lastVerifyDate')._flatpickr;
                if (data.verifyDate) {
                    if (fp) {
                        fp.setDate(data.verifyDate, true); 
                    } else {
                        document.getElementById('lastVerifyDate').value = data.verifyDate;
                        calculateVerifyValidity();
                    }
                } else {
                    if (fp) fp.clear();
                    document.getElementById('verifyValidityAlert').innerHTML = `<div class="alert alert-warning py-2 mb-0 small fw-bold"><i class="fas fa-exclamation-triangle me-1"></i> ไม่พบประวัติผลตรวจเดิมในระบบ - ต้องตรวจใหม่</div>`;
                    document.getElementById('verifyMethod').value = "ต้องส่งตรวจใหม่ผ่านระบบ";
                    toggleVerifyAction();
                }

                listContainer.innerHTML = '';
            };
            listContainer.appendChild(div);
        });
        
        const divNew = document.createElement('div');
        divNew.innerHTML = `<span class="text-primary fw-bold"><i class="fas fa-plus-circle me-1"></i> ใช้ข้อมูลนี้เป็นรายการใหม่ "${val}"</span>`;
        divNew.onclick = function() {
            document.getElementById('maidCode').value = val;
            listContainer.innerHTML = '';
        };
        listContainer.appendChild(divNew);
    }
    
    document.addEventListener("click", function(e) {
        if(e.target.id !== "maidCode") document.getElementById('autocomplete-list').innerHTML = '';
    });

    function openAddModal() {
       document.getElementById('dataForm').reset();
       document.getElementById('recordId').value = "";
       document.getElementById('hasFastTrackStatus').value = "";
       document.getElementById('modalTitle').textContent = "บันทึกคุณแม่บ้านขอกลับมาทำใหม่ (กลุ่ม H)";
       
       document.getElementById('idCard').classList.remove('is-invalid', 'is-valid');
       
       document.querySelectorAll('.dynamic-tag').forEach(cb => cb.checked = false);
       currentHistory = []; renderTimeline();
       
       toggleRetrain();
       toggleVerifyAction();
       document.getElementById('verifyValidityAlert').innerHTML = `<div class="alert alert-secondary py-2 mb-0 small">กรุณาระบุวันที่เพื่อคำนวณอายุผลตรวจ</div>`;
       document.getElementById('status').value = "รอดำเนินการ";
